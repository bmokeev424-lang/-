# ============================================
# Настройки SMTP для отправки email
# ============================================

# Gmail (рекомендуется):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your.email@gmail.com
# SMTP_PASS=your_app_password  # Пароль приложения Gmail (16 символов)

# Yandex Mail:
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your.email@yandex.ru
# SMTP_PASS=your_password

# Mail.ru:
# SMTP_HOST=smtp.mail.ru
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your.email@mail.ru
# SMTP_PASS=your_password

# ============================================
# ВАШИ НАСТРОЙКИ (замените на свои)
# ============================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=bmokeev424@gmail.com
SMTP_PASS=your_app_password_here

# Куда отправлять заявки (если не указано, используется SMTP_USER)
RECIPIENT_EMAIL=bmokeev424@gmail.com

# Порт сервера
PORT=3001